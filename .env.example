# ===== Django =====
SECRET_KEY=your-very-long-random-secret-key-here

# 開発時: True / 本番時: False
DEBUG=False

# カンマ区切りで複数指定可
ALLOWED_HOSTS=yourdomain.com,localhost,127.0.0.1

# ===== Database (PostgreSQL) =====
DB_NAME=pmm_db
DB_USER=pmm_user
DB_PASSWORD=your-db-password-here
# Docker Compose 内では "db"、ローカル開発では "localhost"
DB_HOST=db
DB_PORT=5432

# ===== CORS / CSRF =====
# 本番: https://yourdomain.com
# 開発: http://localhost:5173
CORS_ORIGIN_WHITELIST=https://yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# ===== Cloudflare Tunnel =====
# https://one.dash.cloudflare.com/ の Zero Trust > Networks > Tunnels でトークンを取得
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token-here
